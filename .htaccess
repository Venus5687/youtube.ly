RewriteRule ^rest/musicals/top$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/v2/musicals/hot/$ rest/v2/musicals/hot.php [L]
RewriteRule ^rest/v2/musicals/loop/$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/v2/musicals/nearby/$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/v2/musicals/bytrack/$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/v2/musicals/bytrack$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/musicals/bytrack/$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/musicals/bytrack$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/v2/musicals/top/$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/musicals/hot/$ rest/v2/musicals/hot.php [L]
