RewriteRule ^rest/users/(.*)$ rest/v2/users/number.php [L]
RewriteRule ^rest/v2/users/(.*)$ rest/v2/users/number.php [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^servevid/(.*)$ serve.php?vid=$1 [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ serve.php?url=$1 [L]
