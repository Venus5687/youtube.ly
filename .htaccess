RewriteRule ^musically/inspirations/inspiration_data.json$ rest/v2/musicals/feed.php [L]
RewriteRule ^login.do$ login.do.php [L]
RewriteRule ^rest/passport/v2/login$ login.do.php [L]
RewriteRule ^rest/v2/musicals/$ rest/v2/musicals/feed.php [L]
RewriteRule ^rest/comments/$ rest/comments.json [L]
RewriteRule ^rest/comments$ rest/comments.json [L]
RewriteRule ^rest/v2/comments/$ rest/comments.json [L]
RewriteRule ^rest/v2/comments$ rest/comments.json [L]
RewriteRule ^rest/v2/musicals/hot$ rest/v2/musicals/hot.php [L]
